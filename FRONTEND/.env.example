# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Backend API ───────────────────────────────────────────────────────────────
VITE_API_URL=https://kaargar.onrender.com/v1

# ── Razorpay (public/test key only — never put secret here) ─────────────────
# Use rzp_test_xxx for testing, rzp_live_xxx for production
VITE_RAZORPAY_KEY_ID=rzp_test_xxx

# ── Mapbox (map rendering) ────────────────────────────────────────────────────
# Used by PuneMap.jsx, JobTrackingMap.jsx, and SearchingPage.jsx to render the
# live search/tracking maps. Was missing from this file previously — required
# at runtime for those screens to work.
VITE_MAPBOX_TOKEN=pk.xxx

# ── Phone-call cipher key ──────────────────────────────────────────────────────
# AES-256-GCM key (base64, 32 bytes), MUST match the backend's PHONE_CALL_CIPHER_KEY.
# Used by lib/phoneCipher.js to decrypt the masked phone number returned by
# GET /jobs/{id}/contact for the in-app "call" feature. Was missing from this
# file previously.
VITE_PHONE_CALL_KEY=
