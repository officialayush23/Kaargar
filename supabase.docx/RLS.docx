-- MASK PHONE
CREATE OR REPLACE FUNCTION public.mask_phone(p text)
RETURNS text AS $$
BEGIN
  IF p IS NULL THEN RETURN NULL; END IF;
  RETURN concat(left(p, 3), repeat('*', GREATEST(char_length(p)-6,0)), right(p,3));
END;
$$ LANGUAGE plpgsql IMMUTABLE;

-- SEARCH_WORKERS (DB-side filtering + ranking)
CREATE OR REPLACE FUNCTION public.search_workers(
  p_lat double precision,
  p_lon double precision,
  p_radius_meters integer DEFAULT 10000,
  p_category text DEFAULT NULL,
  p_min_hourly numeric DEFAULT NULL,
  p_max_hourly numeric DEFAULT NULL,
  p_limit integer DEFAULT 50
)
RETURNS TABLE (
  worker_id uuid,
  name text,
  rating_avg numeric,
  rating_count integer,
  hourly_rate numeric,
  distance_m double precision,
  matching_job_id uuid,
  matched_job_max_pay numeric,
  trouble_score numeric
) LANGUAGE sql STABLE AS $$
WITH candidate_workers AS (
  SELECT u.id as worker_id,
         u.name,
         u.rating_avg,
         u.rating_count,
         wp.hourly_rate,
         wp.min_hourly_rate,
         wp.max_hourly_rate,
         wp.search_radius_km,
         u.is_flagged,
         COALESCE(u.trouble_score, 0) AS trouble_score,
         ST_Distance(u.location, ST_SetSRID(ST_MakePoint(p_lon, p_lat)::geography,4326)) AS distance_m
  FROM public.users u
  JOIN public.worker_profiles wp ON wp.user_id = u.id
  WHERE u.is_active = true
    AND (u.is_flagged IS NOT TRUE)
    AND (
      p_category IS NULL
      OR EXISTS (SELECT 1 FROM unnest(wp.professions) p WHERE lower(p) = lower(p_category))
    )
    AND (
      (wp.accepts_remote IS TRUE AND p_radius_meters IS NULL)
      OR ST_DWithin(u.location, ST_SetSRID(ST_MakePoint(p_lon,p_lat)::geography,4326), GREATEST(COALESCE(p_radius_meters,10000), wp.search_radius_km * 1000))
    )
)
, highest_job_per_worker AS (
  SELECT cw.*,
         j.id AS matching_job_id,
         GREATEST(COALESCE(j.price_max, j.price_min, 0), COALESCE(b.max_bid,0)) AS matched_job_max_pay
  FROM candidate_workers cw
  LEFT JOIN LATERAL (
    SELECT j.id, j.price_min, j.price_max
    FROM public.jobs j
    WHERE j.status = 'posted'
      AND (p_category IS NULL OR lower(j.category) = lower(p_category))
      AND (j.is_remote = true OR ST_DWithin(j.location, ST_SetSRID(ST_MakePoint(p_lon,p_lat)::geography,4326), GREATEST(COALESCE(p_radius_meters,10000), cw.search_radius_km * 1000)))
    ORDER BY GREATEST(COALESCE(j.price_max, j.price_min, 0), 0) DESC
    LIMIT 1
  ) j ON true
  LEFT JOIN LATERAL (
    SELECT MAX(amount) AS max_bid FROM public.bids b WHERE b.job_id = j.id
  ) b ON true
)
SELECT worker_id, name, rating_avg, rating_count, hourly_rate, distance_m, matching_job_id, matched_job_max_pay, trouble_score
FROM highest_job_per_worker
WHERE (p_min_hourly IS NULL OR hourly_rate >= p_min_hourly)
  AND (p_max_hourly IS NULL OR hourly_rate <= p_max_hourly)
ORDER BY COALESCE(matched_job_max_pay, 0) DESC, rating_avg DESC, distance_m ASC
LIMIT p_limit;
$$;

-- FEE RULE: get effective pct
CREATE OR REPLACE FUNCTION public.get_effective_fee_pct(p_job_id uuid, p_company_id uuid, p_worker_id uuid, p_category text)
RETURNS numeric LANGUAGE plpgsql STABLE AS $$
DECLARE
  res numeric;
BEGIN
  SELECT pct INTO res FROM public.fee_rules
    WHERE active AND scope = 'worker' AND scope_id = p_worker_id
    ORDER BY precedence ASC LIMIT 1;
  IF res IS NOT NULL THEN RETURN res; END IF;

  IF p_company_id IS NOT NULL THEN
    SELECT pct INTO res FROM public.fee_rules
      WHERE active AND scope = 'company' AND scope_id = p_company_id
      ORDER BY precedence ASC LIMIT 1;
    IF res IS NOT NULL THEN RETURN res; END IF;
  END IF;

  IF p_category IS NOT NULL THEN
    SELECT pct INTO res FROM public.fee_rules
      WHERE active AND scope = 'category' AND lower(category) = lower(p_category)
      ORDER BY precedence ASC LIMIT 1;
    IF res IS NOT NULL THEN RETURN res; END IF;
  END IF;

  SELECT pct INTO res FROM public.fee_rules
    WHERE active AND scope = 'global'
    ORDER BY precedence ASC LIMIT 1;

  RETURN COALESCE(res, 0);
END;
$$;

-- PROCESS PAYMENT CAPTURED (idempotent-ish)
CREATE OR REPLACE FUNCTION public.process_payment_captured(
  p_payment_id uuid,
  p_provider_payment_id text,
  p_amount numeric(12,2)
) RETURNS void LANGUAGE plpgsql AS $$
DECLARE
  v_job_id uuid;
  v_worker_id uuid;
  v_company_id uuid;
  v_category text;
  v_pct numeric;
  v_platform_fee numeric;
  v_amount_to_worker numeric;
  v_existing text;
  v_platform_user uuid;
BEGIN
  SELECT status INTO v_existing FROM public.payments WHERE id = p_payment_id;
  IF v_existing IS NULL THEN
    RAISE EXCEPTION 'payment not found %', p_payment_id;
  END IF;
  IF v_existing = 'captured' OR v_existing = 'released' OR v_existing = 'refunded' THEN
    RETURN;
  END IF;

  SELECT job_id INTO v_job_id FROM public.payments WHERE id = p_payment_id;
  IF v_job_id IS NOT NULL THEN
    SELECT assigned_worker_id, company_id, category INTO v_worker_id, v_company_id, v_category FROM public.jobs WHERE id = v_job_id;
  ELSE
    v_worker_id := NULL; v_company_id := NULL; v_category := NULL;
  END IF;

  SELECT platform_fee_pct INTO v_pct FROM public.payments WHERE id = p_payment_id;
  IF v_pct IS NULL THEN
    v_pct := public.get_effective_fee_pct(v_job_id, v_company_id, v_worker_id, v_category);
  END IF;

  v_platform_fee := ROUND((p_amount * v_pct) / 100.0, 2);
  v_amount_to_worker := ROUND(p_amount - v_platform_fee, 2);

  UPDATE public.payments
  SET status = 'captured',
      provider_payment_id = p_provider_payment_id,
      amount_total = p_amount,
      platform_fee = v_platform_fee,
      amount_to_worker = v_amount_to_worker,
      platform_fee_pct = v_pct,
      created_at = COALESCE(created_at, now())
  WHERE id = p_payment_id;

  -- create or find platform user record for ledger (you should have one platform user)
  SELECT id INTO v_platform_user FROM public.users WHERE role && ARRAY['platform','admin']::text[] LIMIT 1;
  IF v_worker_id IS NOT NULL THEN
    INSERT INTO public.wallets (user_id, balance, reserved, updated_at)
      VALUES (v_worker_id, 0, v_amount_to_worker, now())
    ON CONFLICT (user_id) DO UPDATE
      SET reserved = public.wallets.reserved + v_amount_to_worker, updated_at = now();

    INSERT INTO public.wallet_transactions (id, user_id, amount, kind, reference_id, metadata, created_at)
      VALUES (gen_random_uuid(), v_worker_id, v_amount_to_worker, 'reserved', p_payment_id, jsonb_build_object('note','auto-reserve on capture'), now());
  ELSE
    IF v_platform_user IS NOT NULL THEN
      INSERT INTO public.wallet_transactions (id, user_id, amount, kind, reference_id, metadata, created_at)
      VALUES (gen_random_uuid(), v_platform_user, p_amount, 'platform_hold', p_payment_id, jsonb_build_object('note','no-worker assigned, platform hold'), now());
    END IF;
  END IF;

  IF v_platform_user IS NOT NULL THEN
    INSERT INTO public.wallet_transactions (id, user_id, amount, kind, reference_id, metadata, created_at)
      VALUES (gen_random_uuid(), v_platform_user, v_platform_fee, 'platform_fee', p_payment_id, jsonb_build_object('note','platform fee on capture'), now());
  END IF;

  INSERT INTO public.events (entity_type, entity_id, event_type, payload, created_at)
    VALUES ('payment', p_payment_id, 'captured', jsonb_build_object('provider_payment_id', p_provider_payment_id, 'amount', p_amount, 'fee_pct', v_pct), now());
END;
$$;

-- SCHEDULE PAYOUT (creates payouts row)
CREATE OR REPLACE FUNCTION public.schedule_payout_for_payment(p_payment_id uuid, p_provider text)
RETURNS uuid LANGUAGE plpgsql AS $$
DECLARE
  v_worker uuid;
  v_amount numeric(12,2);
  v_platform_fee numeric(12,2);
  v_job_id uuid;
  v_pid uuid;
BEGIN
  SELECT job_id, amount_to_worker, platform_fee INTO v_job_id, v_amount, v_platform_fee FROM public.payments WHERE id = p_payment_id;
  IF v_job_id IS NOT NULL THEN
    SELECT assigned_worker_id INTO v_worker FROM public.jobs WHERE id = v_job_id;
  ELSE
    v_worker := NULL;
  END IF;

  IF v_worker IS NULL THEN
    RAISE EXCEPTION 'No assigned worker for payment %', p_payment_id;
  END IF;

  INSERT INTO public.payouts (payment_id, worker_id, amount, platform_fee, provider)
  VALUES (p_payment_id, v_worker, v_amount, v_platform_fee, p_provider)
  RETURNING id INTO v_pid;

  UPDATE public.payments SET payout_status = 'scheduled', payout_scheduled_at = now() WHERE id = p_payment_id;

  RETURN v_pid;
END;
$$;

-- MARK PAYOUT RESULT
CREATE OR REPLACE FUNCTION public.mark_payout_result(
  p_payout_id uuid,
  p_provider_payout_id text,
  p_status text,
  p_error text DEFAULT NULL
) RETURNS void LANGUAGE plpgsql AS $$
DECLARE
  v_payment uuid;
  v_worker uuid;
  v_amount numeric;
BEGIN
  SELECT payment_id, worker_id, amount INTO v_payment, v_worker, v_amount FROM public.payouts WHERE id = p_payout_id;

  IF p_status = 'success' THEN
    UPDATE public.payouts SET status = 'success', provider_payout_id = p_provider_payout_id, attempted_at = now(), error = NULL WHERE id = p_payout_id;
    UPDATE public.payments SET payout_status = 'paid', payout_provider_id = p_provider_payout_id WHERE id = v_payment;

    UPDATE public.wallets SET reserved = GREATEST(reserved - v_amount, 0) WHERE user_id = v_worker;
    INSERT INTO public.wallet_transactions (id, user_id, amount, kind, reference_id, metadata, created_at)
      VALUES (gen_random_uuid(), v_worker, v_amount, 'payout', v_payment, jsonb_build_object('note','payout to bank'), now());

  ELSIF p_status = 'failed' THEN
    UPDATE public.payouts SET status = 'failed', provider_payout_id = p_provider_payout_id, attempted_at = now(), error = p_error WHERE id = p_payout_id;
    UPDATE public.payments SET payout_status = 'failed' WHERE id = v_payment;

  ELSE
    UPDATE public.payouts SET status = p_status, provider_payout_id = p_provider_payout_id, attempted_at = now(), error = p_error WHERE id = p_payout_id;
    UPDATE public.payments SET payout_status = p_status WHERE id = v_payment;
  END IF;

  INSERT INTO public.events(entity_type, entity_id, event_type, payload, created_at)
    VALUES ('payout', p_payout_id, 'payout_update', jsonb_build_object('status', p_status, 'provider_id', p_provider_payout_id, 'error', p_error), now());
END;
$$;
