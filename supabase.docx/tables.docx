-- ========== A. SCHEMA (tables, views, indexes) ==========
-- Run once (if extensions not present)
CREATE EXTENSION IF NOT EXISTS "pgcrypto";
CREATE EXTENSION IF NOT EXISTS postgis;
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- USERS
CREATE TABLE IF NOT EXISTS public.users (
  id uuid PRIMARY KEY,                          
  email text UNIQUE NOT NULL,
  name text,
  phone text,                                   
  phone_masked text,                            
  gender text,
  birthdate date,
  created_at timestamptz DEFAULT now(),
  role text[] DEFAULT ARRAY['customer']::text[],-- e.g. {'customer','worker','part_time','company_admin','admin'}
  location geography(Point,4326),
  rating_avg numeric(3,2) DEFAULT 0,
  rating_count integer DEFAULT 0,
  kyc_status text DEFAULT 'none',               
  is_active boolean DEFAULT true,
  cancellation_count integer DEFAULT 0,         
  complaints_count integer DEFAULT 0,           
  is_flagged boolean DEFAULT false,             
  trouble_score numeric(6,2) DEFAULT 0,         
  tags text[] DEFAULT '{}'::text[],              
  metadata jsonb DEFAULT '{}'::jsonb
);

CREATE INDEX IF NOT EXISTS idx_users_location ON public.users USING GIST (location);
CREATE INDEX IF NOT EXISTS idx_users_rating ON public.users (rating_avg DESC);
CREATE INDEX IF NOT EXISTS idx_users_tags_gin ON public.users USING GIN (tags);

-- WORKER_PROFILES
CREATE TABLE IF NOT EXISTS public.worker_profiles (
  user_id uuid PRIMARY KEY REFERENCES public.users(id) ON DELETE CASCADE,
  professions text[] DEFAULT '{}'::text[],      
  skills text[] DEFAULT '{}'::text[],
  education jsonb DEFAULT '[]'::jsonb,          
  hourly_rate numeric(12,2),
  base_rate numeric(12,2),
  min_hourly_rate numeric(12,2),                
  max_hourly_rate numeric(12,2),
  accepts_remote boolean DEFAULT false,
  bio text,
  availability jsonb DEFAULT '{}'::jsonb,       
  documents jsonb DEFAULT '{}'::jsonb,         
  max_concurrent_jobs integer DEFAULT 1,        
  search_radius_km integer DEFAULT 10,          
  tags text[] DEFAULT '{}'::text[],              
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_worker_professions_gin ON public.worker_profiles USING GIN (professions);
CREATE INDEX IF NOT EXISTS idx_worker_skills_gin ON public.worker_profiles USING GIN (skills);
CREATE INDEX IF NOT EXISTS idx_worker_tags_gin ON public.worker_profiles USING GIN (tags);

-- COMPANIES
CREATE TABLE IF NOT EXISTS public.companies (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  name text NOT NULL,
  company_type text,
  contact_email text,
  contact_phone text,
  address text,
  location geography(Point,4326),
  created_by uuid REFERENCES public.users(id),
  kyc_status text DEFAULT 'pending',
  metadata jsonb DEFAULT '{}'::jsonb,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_companies_location ON public.companies USING GIST (location);

CREATE TABLE IF NOT EXISTS public.company_users (
  company_id uuid REFERENCES public.companies(id) ON DELETE CASCADE,
  user_id uuid REFERENCES public.users(id) ON DELETE CASCADE,
  role text DEFAULT 'admin',
  created_at timestamptz DEFAULT now(),
  PRIMARY KEY (company_id, user_id)
);

CREATE TABLE IF NOT EXISTS public.company_employees (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  company_id uuid NOT NULL REFERENCES public.companies(id) ON DELETE CASCADE,
  worker_id uuid NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
  employment_status text DEFAULT 'active',
  external_id text,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_company_employee_worker ON public.company_employees(worker_id);
CREATE INDEX IF NOT EXISTS idx_company_employees_company ON public.company_employees(company_id);

-- JOBS
CREATE TABLE IF NOT EXISTS public.jobs (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  customer_id uuid NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
  company_id uuid REFERENCES public.companies(id),
  title text NOT NULL,
  description text,
  category text,
  tags text[] DEFAULT '{}'::text[],
  location geography(Point,4326),
  is_remote boolean DEFAULT false,
  price_type text NOT NULL CHECK (price_type IN ('fixed','hourly','bidding')),
  price_min numeric(12,2),
  price_max numeric(12,2),
  scheduled_start timestamptz,
  scheduled_end timestamptz,
  status text NOT NULL DEFAULT 'draft',
  assigned_worker_id uuid REFERENCES public.users(id),
  posted_at timestamptz,
  created_at timestamptz DEFAULT now(),
  expires_at timestamptz,
  metadata jsonb DEFAULT '{}'::jsonb
);

CREATE INDEX IF NOT EXISTS idx_jobs_location ON public.jobs USING GIST (location);
CREATE INDEX IF NOT EXISTS idx_jobs_status ON public.jobs(status);
CREATE INDEX IF NOT EXISTS idx_jobs_category ON public.jobs(category);
CREATE INDEX IF NOT EXISTS idx_jobs_price ON public.jobs(price_min, price_max);
CREATE INDEX IF NOT EXISTS idx_jobs_sched ON public.jobs (scheduled_start, scheduled_end);

-- BIDS
CREATE TABLE IF NOT EXISTS public.bids (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid NOT NULL REFERENCES public.jobs(id) ON DELETE CASCADE,
  worker_id uuid NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
  company_id uuid REFERENCES public.companies(id),
  amount numeric(12,2),
  message text,
  status text NOT NULL DEFAULT 'pending',
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_bids_job ON public.bids(job_id);

-- ASSIGNMENTS
CREATE TABLE IF NOT EXISTS public.assignments (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid NOT NULL REFERENCES public.jobs(id) UNIQUE,
  worker_id uuid NOT NULL REFERENCES public.users(id),
  company_id uuid REFERENCES public.companies(id),
  scheduled_start timestamptz NOT NULL,
  scheduled_end timestamptz NOT NULL,
  status text NOT NULL DEFAULT 'pending_worker_accept',
  created_at timestamptz DEFAULT now(),
  accepted_at timestamptz,
  declined_at timestamptz,
  cancelled_at timestamptz
);

CREATE INDEX IF NOT EXISTS idx_assignments_worker_time ON public.assignments(worker_id, scheduled_start, scheduled_end);

-- PAYMENTS
CREATE TABLE IF NOT EXISTS public.payments (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid REFERENCES public.jobs(id),
  payer_id uuid REFERENCES public.users(id),
  payee_id uuid REFERENCES public.users(id),
  company_id uuid REFERENCES public.companies(id),
  provider text,
  provider_payment_id text,
  amount_total numeric(12,2) NOT NULL DEFAULT 0,
  platform_fee numeric(12,2) DEFAULT 0,
  amount_to_worker numeric(12,2) DEFAULT 0,
  provider_charge numeric(12,2) DEFAULT 0,
  coupon_id uuid,
  status text NOT NULL DEFAULT 'initiated',
  platform_fee_pct numeric(5,2) DEFAULT NULL,
  payout_status text DEFAULT 'not_initiated',
  payout_provider_id text,
  payout_attempts integer DEFAULT 0,
  payout_scheduled_at timestamptz,
  created_at timestamptz DEFAULT now(),
  metadata jsonb DEFAULT '{}'::jsonb
);

CREATE INDEX IF NOT EXISTS idx_payments_job ON public.payments(job_id);

-- WALLET + LEDGER
CREATE TABLE IF NOT EXISTS public.wallets (
  user_id uuid PRIMARY KEY REFERENCES public.users(id) ON DELETE CASCADE,
  balance numeric(12,2) DEFAULT 0,
  reserved numeric(12,2) DEFAULT 0,
  updated_at timestamptz DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.wallet_transactions (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id uuid REFERENCES public.users(id),
  amount numeric(12,2) NOT NULL,
  kind text NOT NULL,
  reference_id uuid,
  metadata jsonb DEFAULT '{}'::jsonb,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_wallet_tx_user ON public.wallet_transactions(user_id);

-- COUPONS
CREATE TABLE IF NOT EXISTS public.coupons (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  code text UNIQUE NOT NULL,
  kind text NOT NULL CHECK(kind IN ('percent','fixed')),
  amount numeric(12,2) NOT NULL,
  max_uses integer DEFAULT 1,
  used_count integer DEFAULT 0,
  expires_at timestamptz,
  created_at timestamptz DEFAULT now()
);

-- KYC
CREATE TABLE IF NOT EXISTS public.kyc_documents (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id uuid NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
  company_id uuid REFERENCES public.companies(id),
  doc_type text NOT NULL,
  storage_key text NOT NULL,
  status text NOT NULL DEFAULT 'uploaded',
  reviewed_by uuid REFERENCES public.users(id),
  reviewed_notes text,
  uploaded_at timestamptz DEFAULT now(),
  reviewed_at timestamptz
);

CREATE INDEX IF NOT EXISTS idx_kyc_user ON public.kyc_documents(user_id);

-- RATINGS
CREATE TABLE IF NOT EXISTS public.ratings (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid REFERENCES public.jobs(id),
  from_user_id uuid NOT NULL REFERENCES public.users(id),
  to_user_id uuid NOT NULL REFERENCES public.users(id),
  rating smallint CHECK (rating BETWEEN 1 AND 5),
  review_text text,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_ratings_to ON public.ratings(to_user_id);

-- DISPUTES
CREATE TABLE IF NOT EXISTS public.disputes (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid REFERENCES public.jobs(id),
  opened_by uuid REFERENCES public.users(id),
  reason text,
  status text DEFAULT 'open',
  resolution text,
  created_at timestamptz DEFAULT now(),
  resolved_at timestamptz
);

-- MEDIA
CREATE TABLE IF NOT EXISTS public.media_attachments (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  owner_id uuid REFERENCES public.users(id),
  company_id uuid REFERENCES public.companies(id),
  job_id uuid REFERENCES public.jobs(id),
  assignment_id uuid REFERENCES public.assignments(id),
  storage_key text NOT NULL,
  filename text,
  mime_type text,
  size_bytes integer,
  tag text,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_media_job ON public.media_attachments(job_id);

-- INVOICES
CREATE TABLE IF NOT EXISTS public.invoices (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid REFERENCES public.jobs(id),
  created_by uuid REFERENCES public.users(id),
  company_id uuid REFERENCES public.companies(id),
  total_amount numeric(12,2) NOT NULL,
  currency text DEFAULT 'INR',
  submitted_at timestamptz DEFAULT now(),
  verified boolean DEFAULT false,
  verification_score numeric(5,2),
  verification_notes text,
  metadata jsonb DEFAULT '{}'::jsonb
);

CREATE TABLE IF NOT EXISTS public.invoice_items (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  invoice_id uuid REFERENCES public.invoices(id) ON DELETE CASCADE,
  description text,
  quantity numeric DEFAULT 1,
  unit_price numeric(12,2),
  total_price numeric(12,2),
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_invoice_job ON public.invoices(job_id);

-- CHAT / MESSAGES
CREATE TABLE IF NOT EXISTS public.chats (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id uuid REFERENCES public.jobs(id),
  created_at timestamptz DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.messages (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  chat_id uuid REFERENCES public.chats(id) ON DELETE CASCADE,
  sender_id uuid REFERENCES public.users(id),
  body text,
  attachments jsonb DEFAULT '[]'::jsonb,
  read_by jsonb DEFAULT '[]'::jsonb,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_messages_chat ON public.messages(chat_id);

-- PUSH
CREATE TABLE IF NOT EXISTS public.push_tokens (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id uuid REFERENCES public.users(id),
  provider text NOT NULL,
  token text NOT NULL,
  platform text,
  meta jsonb DEFAULT '{}'::jsonb,
  last_seen timestamptz DEFAULT now(),
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_push_tokens_user ON public.push_tokens(user_id);

CREATE TABLE IF NOT EXISTS public.push_notifications (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  recipient_id uuid REFERENCES public.users(id),
  sender_id uuid REFERENCES public.users(id),
  channel text NOT NULL CHECK (channel IN ('push','email','sms','inapp')),
  title text,
  body text,
  data jsonb DEFAULT '{}'::jsonb,
  provider_message_id text,
  status text NOT NULL DEFAULT 'queued',
  error text,
  ttl integer,
  sent_at timestamptz,
  delivered_at timestamptz,
  clicked_at timestamptz,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_push_notifications_recipient ON public.push_notifications(recipient_id);
CREATE INDEX IF NOT EXISTS idx_push_notifications_status ON public.push_notifications(status);

-- EVENTS / WEBHOOK LOGS
CREATE TABLE IF NOT EXISTS public.events (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  entity_type text,
  entity_id uuid,
  event_type text,
  payload jsonb DEFAULT '{}'::jsonb,
  created_at timestamptz DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.webhook_logs (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  provider text,
  provider_event jsonb,
  received_at timestamptz DEFAULT now()
);

-- FEE_RULES & PAYOUTS
CREATE TABLE IF NOT EXISTS public.fee_rules (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  scope text NOT NULL CHECK (scope IN ('global','company','category','worker')),
  scope_id uuid,
  category text,
  pct numeric(5,2) NOT NULL,
  active boolean DEFAULT true,
  precedence integer DEFAULT 100,
  created_at timestamptz DEFAULT now()
);

-- Ensure a default global fee exists
INSERT INTO public.fee_rules (scope, pct, precedence)
SELECT 'global', 10.00, 100
WHERE NOT EXISTS (SELECT 1 FROM public.fee_rules WHERE scope = 'global' AND active = true);

CREATE TABLE IF NOT EXISTS public.payouts (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  payment_id uuid REFERENCES public.payments(id),
  worker_id uuid REFERENCES public.users(id),
  amount numeric(12,2) NOT NULL,
  platform_fee numeric(12,2),
  provider text,
  provider_payout_id text,
  status text DEFAULT 'created',
  error text,
  attempted_at timestamptz DEFAULT now(),
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_payouts_payment ON public.payouts(payment_id);

-- VIEW: public user_public_profiles (safe view for frontend)
CREATE OR REPLACE VIEW public.user_public_profiles AS
SELECT
  u.id,
  u.name,
  u.phone_masked,
  u.rating_avg,
  u.rating_count,
  u.kyc_status,
  u.is_active,
  wp.professions,
  wp.skills,
  wp.hourly_rate,
  wp.min_hourly_rate,
  wp.max_hourly_rate,
  wp.accepts_remote,
  u.location,
  u.tags,
  wp.tags AS worker_tags,
  u.metadata
FROM public.users u
LEFT JOIN public.worker_profiles wp ON wp.user_id = u.id;
GRANT SELECT ON public.user_public_profiles TO authenticated;



-- 1.1: mark profile completion flags and make role canonical easier to query
ALTER TABLE public.users
  ADD COLUMN IF NOT EXISTS profile_completed boolean DEFAULT false,
  ADD COLUMN IF NOT EXISTS last_seen_at timestamptz;

-- 1.2: per-worker profile completion flag
ALTER TABLE public.worker_profiles
  ADD COLUMN IF NOT EXISTS profile_completed boolean DEFAULT false,
  ADD COLUMN IF NOT EXISTS kyc_status text DEFAULT 'none'; -- mirrors users.kyc_status for worker-specific

-- 1.3: add some explicit columns for quick indexing / searching
ALTER TABLE public.worker_profiles
  ADD COLUMN IF NOT EXISTS operating_radius_km integer DEFAULT 10,
  ADD COLUMN IF NOT EXISTS min_hourly_rate_cents bigint,
  ADD COLUMN IF NOT EXISTS max_hourly_rate_cents bigint;

-- backfill example (convert rupee decimal->cents) - run if you use rupee decimals
UPDATE public.worker_profiles
SET min_hourly_rate_cents = (min_hourly_rate * 100)::bigint
WHERE min_hourly_rate IS NOT NULL AND min_hourly_rate_cents IS NULL;

UPDATE public.worker_profiles
SET max_hourly_rate_cents = (max_hourly_rate * 100)::bigint
WHERE max_hourly_rate IS NOT NULL AND max_hourly_rate_cents IS NULL;

-- 1.4: derived boolean flags for fast queries (indexed)
ALTER TABLE public.users ADD COLUMN IF NOT EXISTS cancels_often boolean DEFAULT false;
ALTER TABLE public.users ADD COLUMN IF NOT EXISTS has_complaints boolean DEFAULT false;
CREATE INDEX IF NOT EXISTS idx_users_cancels_often ON public.users (cancels_often);
CREATE INDEX IF NOT EXISTS idx_users_has_complaints ON public.users (has_complaints);

-- 1.5: KYC audit table (who reviewed, when)
CREATE TABLE IF NOT EXISTS public.kyc_reviews (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  kyc_document_id uuid REFERENCES public.kyc_documents(id) ON DELETE CASCADE,
  reviewer_id uuid REFERENCES public.users(id),
  review_action text CHECK (review_action IN ('approved','rejected','needs_info')),
  notes text,
  reviewed_at timestamptz DEFAULT now()
);
